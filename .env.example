# Set to 1 to enable debug logging to context.log, or 0 to disable it. You can also set this in your environment or override it in the MCP config for your client.
DEBUG=0

# MCP Transport Mode
# Choose the transport protocol for the MCP server:
#   - "stdio" (default): Standard input/output. The MCP client (VS Code, Cursor, Claude Desktop, etc.) launches the server
#     as a local subprocess.
#   - "http": Streamable HTTP. The server runs as a standalone process that clients
#     connect to over HTTP.

MCP_TRANSPORT=stdio

# HTTP Transport Configuration (only used if MCP_TRANSPORT=http)
# MCP_HTTP_HOST=localhost
# MCP_HTTP_PORT=5000

# Public base URL for the MCP server (only needed if MCP_TRANSPORT=http).
# Set this when the server is behind a reverse proxy or TLS termination
# where the public URL differs from the bind address (e.g. https://mcp.example.com).
# Defaults to http://{MCP_HTTP_HOST}:{MCP_HTTP_PORT} if not set.
# MCP_PUBLIC_BASE_URL=https://mcp.example.com

# Evo authentication
# The default setup uses interactive sign-in (opens a browser window).
# See "Configure your Evo credentials" in the README.
# These values can also be set/overridden in your MCP client config.
AUTH_METHOD=native_app
EVO_CLIENT_ID=Replace this with your client ID
# The redirect URL where Bentley IMS sends the auth code after login (non-delegated mode only).
# Must match a registered redirect URI in your IMS application.
# In HTTP mode with CLIENT_DELEGATED_AUTH, the MCP server itself receives the
# OAuth callback at {MCP_PUBLIC_BASE_URL}/auth/callback — register THAT URL in
# your client instead. EVO_REDIRECT_URL is ignored in HTTP+delegated mode.
EVO_REDIRECT_URL=http://localhost:3000/signin-callback
# EVO_CLIENT_SECRET=your-client-secret  # Optional: only needed for client credentials flow

# --- Service authentication (advanced) ---
# For automation, CI/CD, or background services that run without a user.
# To use: comment out the native app settings above, then uncomment below.
# AUTH_METHOD=client_credentials
# EVO_CLIENT_ID=your-service-client-id
# EVO_CLIENT_SECRET=your-service-client-secret

# Multi-user OAuth (CLIENT_DELEGATED_AUTH)
# Only set this to true if ALL of the following apply:
#   - MCP_TRANSPORT=http
#   - AUTH_METHOD=native_app
#   - You want client-delegated auth (each AI client authenticates independently
#     with their own Bentley account and gets their own isolated Evo session)
#
# When enabled, the server acts as an OIDC proxy — MCP clients authenticate via
# a browser OAuth flow and AUTH_METHOD / EVO_CLIENT_SECRET are not used.
# When disabled, the server authenticates as a single shared user (using AUTH_METHOD).
#
# Ignored in STDIO mode (warns if set to true). Defaults to false in HTTP mode.
# CLIENT_DELEGATED_AUTH=true


MCP_TOOL_FILTER=all
# Search path for local data files. Point this to local data you want tools to
# be able to access.
# Defaults to "data" in the repo root.
# EVO_LOCAL_DATA_DIR=D:\data\my-data-files\

# Authority URLs for key systems, you shouldn't need to change these.
ISSUER_URL=https://ims.bentley.com
EVO_DISCOVERY_URL=https://discover.api.seequent.com

# Example Agent Config
EVO_AGENT_MODEL=gemini-2.5-flash

# Example agent ADK config
GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=
